<form>
    <div class="mb-3">
        <label for="studentname" class="form-label">Student Name</label>
        <input type="text" class="form-control" id="studentname" aria-describedby="studentHelp" placeholder="Enter student name">
        <div id="studentHelp" class="form-text">We'll never share your student name with anyone else.</div>
    </div>

    <div class="mb-3">
        <label for="teacherid" class="form-label">Teacher ID</label>
        <input type="text" class="form-control" id="teacherid" aria-describedby="teacherHelp" placeholder="Enter teacher ID">
        <div id="teacherHelp" class="form-text">We'll never share your teacher ID with anyone else.</div>
    </div>
    <div class="form-check">
        <input class="form-check-input" type="checkbox" value="" id="defaultCheck2">
        <label class="form-check-label" for="defaultCheck2">
           Child Is Possibly Dyslexic
        </label>
    </div>
    
    <button type="submit" class="btn btn-primary">Submit</button>
</form>