<div class="container mt-5">
    <h2>Search Teachers</h2>
    
    <form method="get" class="mt-4 mb-4 d-flex">
        <input type="text" name="q" class="form-control me-2" placeholder="Search by name..." value="<?= $this->escapeHtml($this->query) ?>">
        <button type="submit" class="btn btn-primary">Search</button>
    </form>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Teacher Name</th>
                    <th>Teacher ID</th>
                </tr>
            </thead>
            <tbody>
                <?php if (count($this->teachers) > 0): ?>
                    <?php foreach ($this->teachers as $teacher): ?>
                    <tr>
                        <td><?= $teacher->getId() ?></td>
                        <td><?= $this->escapeHtml($teacher->getTeacherName()) ?></td>
                        <td><?= $this->escapeHtml($teacher->getTeacherId()) ?></td>
                    </tr>
                    <?php endforeach; ?>
                <?php else: ?>
                    <tr><td colspan="3" class="text-center">No teachers found matching your query.</td></tr>
                <?php endif; ?>
            </tbody>
        </table>
    </div>
    <a href="<?= $this->url('admin') ?>" class="btn btn-secondary mt-3">Back to Dashboard</a>
</div>
