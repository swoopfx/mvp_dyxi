<div class="container mt-5">
    <h2>Edit Game Bracket</h2>
    <?php if ($this->error): ?>
        <div class="alert alert-danger"><?= $this->error ?></div>
    <?php endif; ?>
    <?php if ($this->success): ?>
        <div class="alert alert-success"><?= $this->success ?></div>
    <?php endif; ?>

    <form method="post" class="mt-4">
        <div class="mb-3">
            <label class="form-label">Bracket Name</label>
            <input type="text" name="bracketName" class="form-control" value="<?= $this->escapeHtml($this->bracket->getBracketName()) ?>" required>
        </div>
        <div class="mb-3">
            <label class="form-label">Bracket ID (Unique Identifier)</label>
            <input type="text" name="bracketId" class="form-control" value="<?= $this->escapeHtml($this->bracket->getBracketId()) ?>" required>
        </div>
        <div class="mb-3">
            <label class="form-label">Age Bracket</label>
            <select name="age" class="form-select" required>
                <option value="">Select Age Bracket...</option>
                <?php foreach ($this->ages as $age): ?>
                    <?php $selected = ($this->bracket->getAge() && $this->bracket->getAge()->getId() == $age->getId()) ? 'selected' : ''; ?>
                    <option value="<?= $age->getId() ?>" <?= $selected ?>><?= $this->escapeHtml($age->getAgeBracket()) ?></option>
                <?php endforeach; ?>
            </select>
        </div>
        <div class="mb-3">
            <label class="form-label">Language</label>
            <select name="language" class="form-select" required>
                <option value="">Select Language...</option>
                <?php foreach ($this->languages as $lang): ?>
                    <?php $selected = ($this->bracket->getLanguage() && $this->bracket->getLanguage()->getId() == $lang->getId()) ? 'selected' : ''; ?>
                    <option value="<?= $lang->getId() ?>" <?= $selected ?>><?= $this->escapeHtml($lang->getLanguage()) ?></option>
                <?php endforeach; ?>
            </select>
        </div>
        <div class="mb-3">
            <label class="form-label">Background ID (Optional)</label>
            <input type="text" name="bgId" class="form-control" value="<?= $this->escapeHtml($this->bracket->getBgId()) ?>">
        </div>
        <div class="mb-3">
            <label class="form-label">Description (Optional)</label>
            <textarea name="description" class="form-control" rows="3"><?= $this->escapeHtml($this->bracket->getDescription()) ?></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Update Bracket</button>
        <a href="<?= $this->url('admin', ['action' => 'view-game-brackets']) ?>" class="btn btn-secondary">Back to List</a>
    </form>
</div>
