<div class="container mt-5">
    <h2>View Game Brackets</h2>
    <div class="table-responsive mt-4">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Bracket Name</th>
                    <th>Bracket ID</th>
                    <th>Age Bracket</th>
                    <th>Language</th>
                    <th>Options</th>
                </tr>
            </thead>
            <tbody>
                <?php if (count($this->brackets) > 0): ?>
                    <?php foreach ($this->brackets as $bracket): ?>
                    <tr>
                        <td><?= $bracket->getId() ?></td>
                        <td><?= $this->escapeHtml($bracket->getBracketName()) ?></td>
                        <td><?= $this->escapeHtml($bracket->getBracketId()) ?></td>
                        <td><?= $bracket->getAge() ? $this->escapeHtml($bracket->getAge()->getAgeBracket()) : 'N/A' ?></td>
                        <td><?= $bracket->getLanguage() ? $this->escapeHtml($bracket->getLanguage()->getLanguage()) : 'N/A' ?></td>
                        <td>
                            <a href="<?= $this->url('admin', ['action' => 'edit-game-bracket']) ?>?id=<?= $bracket->getId() ?>" class="btn btn-sm btn-primary">Edit</a>
                        </td>
                    </tr>
                    <?php endforeach; ?>
                <?php else: ?>
                    <tr><td colspan="6" class="text-center">No game brackets found.</td></tr>
                <?php endif; ?>
            </tbody>
        </table>
    </div>
    <a href="<?= $this->url('admin') ?>" class="btn btn-secondary">Back to Dashboard</a>
</div>
